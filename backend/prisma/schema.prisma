generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String     @id @default(uuid())
  email         String     @unique
  name          String?
  avatar        String?
  passwordHash  String?
  googleId      String?    @unique
  role          String     @default("user")
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  workflows     Workflow[]
  sessions      Session[]
  notifications Notification[]
  globalVars    GlobalVariable[]
}

model Session {
  id            String     @id @default(uuid())
  userId        String
  user          User       @relation(fields: [userId], references: [id])
  token         String     @unique
  ipAddress     String?
  userAgent     String?
  createdAt     DateTime   @default(now())
  expiresAt     DateTime

  @@index([userId])
}

model Workflow {
  id            String     @id @default(uuid())
  userId        String
  user          User       @relation(fields: [userId], references: [id])
  title         String
  description   String?
  startUrl      String
  status        String     @default("draft")
  steps         Json
  variables     Json?
  tags          String[]   @default([])
  sessionId     String     @unique
  metadata      Json?
  isTemplate    Boolean    @default(false)
  schedule      Json?
  runCount      Int        @default(0)
  successRate   Float      @default(0)
  avgDurationMs Int        @default(0)
  thumbnail     String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  executions    Execution[]
  triggers      Trigger[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model Execution {
  id                  String     @id @default(uuid())
  workflowId          String
  workflow            Workflow   @relation(fields: [workflowId], references: [id])
  status              String     @default("queued")
  startedAt           DateTime?
  endedAt             DateTime?
  durationMs          Int?
  stepsCompleted      Int        @default(0)
  stepsTotal          Int        @default(0)
  error               String?
  extractedVariables  Json?
  log                 Json?
  screenshots         String[]
  result              Json?
  createdAt           DateTime   @default(now())
  extractedVars       ExtractedVariable[]

  @@index([workflowId])
  @@index([status])
  @@index([createdAt])
}

model Template {
  id          String   @id @default(uuid())
  name        String
  description String?
  category    String
  icon        String
  workflow    Json
  useCount    Int      @default(0)
  isOfficial  Boolean  @default(true)
  createdBy   String?
  createdAt   DateTime @default(now())

  @@index([category])
}

model GlobalVariable {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  name        String
  value       String
  isSecret    Boolean  @default(false)
  description String?
  environment String   @default("all")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, name])
  @@index([userId])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String
  title     String
  message   String
  isRead    Boolean  @default(false)
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([userId, isRead])
  @@index([createdAt])
}

// ── v8 Evolution Models ────────────────────────────────────────────────────

enum TriggerType {
  MANUAL
  SCHEDULE
  WEBHOOK
  EMAIL
  FILE_WATCH
}

model Trigger {
  id         String      @id @default(uuid())
  workflowId String
  workflow   Workflow    @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  type       TriggerType
  config     Json
  isActive   Boolean     @default(true)
  lastFired  DateTime?
  fireCount  Int         @default(0)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@index([workflowId])
  @@index([type, isActive])
}

model WorkflowChain {
  id               String   @id @default(uuid())
  sourceWorkflowId String
  targetWorkflowId String
  variableMapping  Json
  createdAt        DateTime @default(now())

  @@index([sourceWorkflowId])
  @@index([targetWorkflowId])
}

model ExtractedVariable {
  id          String    @id @default(uuid())
  executionId String
  execution   Execution @relation(fields: [executionId], references: [id], onDelete: Cascade)
  name        String
  value       String
  type        String
  isRedacted  Boolean   @default(false)
  createdAt   DateTime  @default(now())

  @@index([executionId])
}

model PiiRedactionLog {
  id             String   @id @default(uuid())
  workflowId     String?
  executionId    String?
  redactionCount Int      @default(0)
  types          String[]
  originalHash   String
  createdAt      DateTime @default(now())

  @@index([workflowId])
  @@index([createdAt])
}
