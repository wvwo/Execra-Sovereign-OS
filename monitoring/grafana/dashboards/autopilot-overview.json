{
  "dashboard": {
    "id": null,
    "title": "Process Autopilot - نظرة عامة",
    "tags": ["autopilot", "production"],
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "معدل نجاح الـ Workflows",
        "type": "stat",
        "targets": [{
          "expr": "rate(autopilot_workflow_executions_total{status=\"success\"}[5m]) / rate(autopilot_workflow_executions_total[5m])",
          "legendFormat": "نسبة النجاح"
        }],
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "thresholds": {
              "steps": [
                {"color": "red", "value": 0},
                {"color": "yellow", "value": 0.7},
                {"color": "green", "value": 0.8}
              ]
            }
          }
        },
        "gridPos": {"h": 8, "w": 6, "x": 0, "y": 0}
      },
      {
        "id": 2,
        "title": "التنفيذات النشطة",
        "type": "stat",
        "targets": [{
          "expr": "autopilot_active_executions",
          "legendFormat": "تنفيذ نشط"
        }],
        "gridPos": {"h": 8, "w": 6, "x": 6, "y": 0}
      },
      {
        "id": 3,
        "title": "مدة تنفيذ الـ Workflows",
        "type": "graph",
        "targets": [{
          "expr": "histogram_quantile(0.95, rate(autopilot_workflow_execution_duration_seconds_bucket[5m]))",
          "legendFormat": "p95"
        }],
        "yAxes": [{"unit": "s"}],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0}
      },
      {
        "id": 4,
        "title": "مدة طلبات HTTP",
        "type": "graph",
        "targets": [{
          "expr": "histogram_quantile(0.95, rate(autopilot_http_request_duration_seconds_bucket[5m]))",
          "legendFormat": "{{method}} {{route}}"
        }],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8}
      },
      {
        "id": 5,
        "title": "تكلفة تحليل الفيديو",
        "type": "graph",
        "targets": [{
          "expr": "rate(autopilot_vision_cost_usd_total[1h])",
          "legendFormat": "{{vlm_provider}}"
        }],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8}
      },
      {
        "id": 6,
        "title": "التنبيهات الأمنية",
        "type": "table",
        "targets": [{
          "expr": "autopilot_sentinel_alerts_total",
          "format": "table",
          "instant": true
        }],
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 16}
      }
    ],
    "time": {"from": "now-1h", "to": "now"},
    "refresh": "10s"
  }
}
