# Root configuration for Execra Sovereign OS
# ⚠️ IMPORTANT: Generate strong secrets before deployment!
# Run: openssl rand -hex 32

# Authentication
JWT_SECRET=CHANGE_ME_USE_openssl_rand_hex_32

# Vision / AI
OPENAI_API_KEY=your_openai_api_key_here
QWEN_API_KEY=your_qwen_api_key_here

# Database
DB_PASSWORD=CHANGE_ME_USE_openssl_rand_hex_32

# Redis
REDIS_PASSWORD=CHANGE_ME_USE_openssl_rand_hex_32

# Sentinel Security Layer
SENTINEL_API_KEY=CHANGE_ME_USE_openssl_rand_hex_32

# MinIO / S3
S3_ENDPOINT=http://minio:9000
